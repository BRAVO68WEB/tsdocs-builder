{
 "name": "tsdocs-builder",
 "version": "1.0.0",
 "description": "A Bun CLI tool for generating Markdown documentation from TypeScript source code",
 "type": "module",
 "exports": {
 ".": {
 "import": "./dist/index.js",
 "types": "./dist/index.d.ts"
 }
 },
 "bin": {
 "tsdocs": "./bin/tsdocs.js"
 },
 "scripts": {
 "dev": "bun run src/index.ts",
 "build:lib": "tsup",
 "build:bin": "node scripts/build-binary.mjs",
 "build": "bun run build:lib && bun run build:bin",
 "typecheck": "tsc --noEmit",
 "lint": "eslint . && oxlint .",
 "fmt": "biome check --write . && prettier --write '**/*.md' '**/*.json' '**/*.yaml' '**/*.yml'",
 "fmt:check": "biome check . && prettier --check '**/*.md' '**/*.json' '**/*.yaml' '**/*.yml'",
 "test": "vitest run",
 "ci": "bun run fmt:check && bun run lint && bun run typecheck && bun run test && bun run build"
 },
 "dependencies": {
 "minimatch": "^10.2.5",
 "ts-morph": "^28.0.0",
 "@types/bun": "latest"
 },
 "devDependencies": {
 "@types/node": "^22.0.0",
 "@typescript-eslint/eslint-plugin": "^8.0.0",
 "@typescript-eslint/parser": "^8.0.0",
 "eslint": "^8.57.0",
 "eslint-plugin-jsdoc": "^50.0.0",
 "esbuild": "^0.24.0",
 "oxlint": "^0.15.0",
 "prettier": "^3.0.0",
 "@biomejs/biome": "^1.9.0",
 "tsup": "^8.0.0",
 "typescript": "^5.7.0",
 "vitest": "^2.0.0"
 },
 "engines": {
 "node": ">=18.0.0"
 }
}
