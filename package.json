{
  "name": "tsdocs-builder",
  "version": "0.0.3",
  "description": "A Bun CLI tool for generating Markdown documentation from TypeScript source code",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "tsdocs": "./bin/tsdocs.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build:lib": "tsup",
    "build": "bun run build:lib && bun run build:cli",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && oxlint .",
    "fmt": "biome check --write . --max-diagnostics 50 --unsafe",
    "fmt:check": "biome check .",
    "test": "vitest run",
    "ci": "bun run fmt:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "prepublishOnly": "bun run build",
    "release": "bunx changeset publish",
    "build:cli": "node esbuild.config.mjs"
  },
  "dependencies": {
    "minimatch": "^10.2.5",
    "ts-morph": "^28.0.0",
    "@types/bun": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "oxlint": "^0.15.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BRAVO68WEB/tsdocs-builder"
  },
  "bugs": {
    "url": "https://github.com/BRAVO68WEB/tsdocs-builder/issues"
  },
  "homepage": "https://github.com/BRAVO68WEB/tsdocs-builder#readme",
  "publishConfig": {
    "provenance": true
  },
  "license": "MIT"
}
