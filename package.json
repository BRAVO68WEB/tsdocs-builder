{
  "name": "tsdocs-builder",
  "version": "1.0.0",
  "description": "A Bun CLI tool for generating Markdown documentation from TypeScript source code",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "tsdocs": "./bin/tsdocs.js"
  },
  "scripts": {
    "tsdocs": "bun run src/index.ts",
    "build": "bun build --target=bun --compile ./src/index.ts --outfile=tsdocs"
  },
  "dependencies": {
    "minimatch": "^10.2.5",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "esbuild": "^0.28.0",
    "eslint": "8",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
